---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Табак Гросист",
  description = "Табак Гросист (Grosist) ДООЕЛ Битола — премиум дистрибутивна компанија со 35+ години искуство во југо-западна Македонија.",
  image = "/og.png",
} = Astro.props;

// Absolute URLs for canonical + social cards (needs `site` in astro.config).
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);

// LocalBusiness structured data — tells Google that the domain, the brand
// "Табак Гросист / Grosist" and the Bitola distribution business are one and
// the same entity. This is the strongest on-page signal for owning the
// "Grosist" branded search alongside the Google Business Profile.
// NOTE: street address + social links are intentionally omitted until the
// exact values are provided; add `address.streetAddress` and `sameAs` later.
const siteUrl = Astro.site!.origin;
const businessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${siteUrl}/#business`,
  name: "Табак Гросист",
  alternateName: ["Grosist", "Гросист", "Табак Гросист ДООЕЛ Битола"],
  description:
    "Дистрибутивна компанија со седиште во Битола и над 35 години искуство. Дистрибуција до продажните објекти во југо-западна Македонија.",
  url: siteUrl,
  telephone: "+389 78 640 000",
  foundingDate: "1991",
  image: new URL("/og.png", Astro.site).href,
  logo: new URL("/favicon-192.png", Astro.site).href,
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Битола",
    addressRegion: "Пелагонија",
    addressCountry: "MK",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 41.0297,
    longitude: 21.3292,
  },
  areaServed: [
    "Битола",
    "Ресен",
    "Прилеп",
    "Крушево",
    "Охрид",
    "Струга",
    "Кичево",
    "Дебар",
  ].map((name) => ({ "@type": "City", name })),
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    opens: "07:00",
    closes: "15:00",
  },
};
---

<!doctype html>
<html lang="mk">
  <head>
    <!-- Tag iOS Safari synchronously (before paint) so the app-shell scroll
         fix in global.css applies ONLY there. Every other browser keeps the
         original body/window scrolling, untouched. Chrome/Firefox/Edge on iOS
         (CriOS/FxiOS/EdgiOS) are deliberately excluded. -->
    <script is:inline>
      (function () {
        var ua = navigator.userAgent;
        var isIOS =
          /iP(hone|od|ad)/.test(ua) ||
          (navigator.platform === "MacIntel" && navigator.maxTouchPoints > 1);
        var isSafari =
          /Safari/.test(ua) && !/(CriOS|FxiOS|EdgiOS|OPiOS|GSA)/.test(ua);
        if (isIOS && isSafari) {
          document.documentElement.classList.add("ios-safari");
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (Facebook, Viber, WhatsApp, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Табак Гросист" />
    <meta property="og:locale" content="mk_MK" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Табак Гросист ДООЕЛ Битола" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google search uses rel="icon" and prefers a square icon that's a
         multiple of 48px, so we expose 192/96/48 (not just 16/32). -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,500;1,600;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=Oswald:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(businessSchema)}
    />
  </head>
  <body>
    <div id="shell">
      <slot />
    </div>
    <script>
      import "../scripts/site.ts";
    </script>
  </body>
</html>
