---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Табак Гросист",
  description = "Табак Гросист ДООЕЛ Битола, премиум дистрибутивна компанија со 35+ години искуство во југо-западна Македонија.",
  image = "/og.png",
} = Astro.props;

// Absolute URLs for canonical + social cards (needs `site` in astro.config).
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---

<!doctype html>
<html lang="mk">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <!-- Tints the mobile browser chrome (iOS status-bar strip behind the
         Dynamic Island, and the toolbar) to the site's navy so page content
         never bleeds through the top strip and the chrome matches the site. -->
    <meta name="theme-color" content="#0b1322" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (Facebook, Viber, WhatsApp, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Табак Гросист" />
    <meta property="og:locale" content="mk_MK" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Табак Гросист ДООЕЛ Битола" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,500;1,600;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=Oswald:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <!-- Solid bar that physically covers the iOS status-bar / Dynamic Island
         strip so page content can never show behind it while scrolling.
         Height is set at runtime from the measured safe-area inset. -->
    <div class="ios-safe-fill" aria-hidden="true"></div>
    <script is:inline>
      (function () {
        function setSafeTop() {
          var probe = document.createElement("div");
          probe.style.cssText =
            "position:fixed;top:0;left:0;width:0;height:env(safe-area-inset-top);visibility:hidden;pointer-events:none;";
          document.body.appendChild(probe);
          var h = probe.getBoundingClientRect().height;
          probe.remove();
          // Fallback: some iOS Safari states don't expose the inset (reports 0)
          // even on notched devices. Detect a tall iOS screen and cover it.
          var ua = navigator.userAgent;
          var isIOS =
            /iP(hone|od|ad)/.test(ua) ||
            (navigator.platform === "MacIntel" && navigator.maxTouchPoints > 1);
          var s = window.screen || {};
          var tall = Math.max(s.width || 0, s.height || 0) /
            Math.max(1, Math.min(s.width || 0, s.height || 0)) > 2;
          if (h < 1 && isIOS && tall) h = 59;
          document.documentElement.style.setProperty("--safe-top", h + "px");
        }
        setSafeTop();
        window.addEventListener("orientationchange", function () {
          setTimeout(setSafeTop, 300);
        });
      })();
    </script>
    <slot />
    <script>
      import "../scripts/site.ts";
    </script>
  </body>
</html>
